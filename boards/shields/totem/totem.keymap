// The totem keymap is the toucan keymap. The shared file lives in config/
// so the keymap editor edits one source of truth (toucan36.keymap); on push,
// CI uses the include below to build totem firmware from it. The two outer
// pinky SW16 keys are absent from totem's matrix transform, so they remain
// empty on the totem build no matter what the keymap says.
#include "../../../config/toucan36.keymap"
